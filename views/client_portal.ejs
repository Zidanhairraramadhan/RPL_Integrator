<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Client Portal - Integrator</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --slate-50: #f8fafc;
            --slate-800: #1e293b;
            --blue-600: #2563eb;
            --green-600: #16a34a;
        }
        body { background-color: var(--slate-50); font-family: 'Inter', sans-serif; }
        .portal-card { border: 1px solid #e2e8f0; background: white; border-radius: 12px; }
        .btn-primary { background-color: var(--blue-600); border: none; }
        .btn-success { background-color: var(--green-600); border: none; }
        .code-area { background: #1e293b; color: #38bdf8; font-family: monospace; border-radius: 6px; padding: 15px; border: 1px solid #e2e8f0; }
        pre { white-space: pre-wrap; word-wrap: break-word; }
    </style>
</head>
<body>
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="text-center mb-5">
                    <h2 class="fw-bold text-slate-800">Integrator <span style="color: var(--blue-600)">Client Portal</span></h2>
                    <p class="text-muted">Ambil akses token dan uji integrasi untuk 6 aplikasi ekosistem UMKM.</p>
                </div>

                <div class="card portal-card shadow-sm p-4 mb-4">
                    <h5 class="fw-bold mb-3">🔑 Generate Access Token</h5>
                    <p class="small text-muted">Token ini diperlukan untuk otentikasi Bearer pada setiap request API.</p>
                    
                    <div class="input-group mb-3">
                        <input type="text" id="tokenOutput" class="form-control" placeholder="Klik tombol untuk membuat token..." readonly>
                        <button class="btn btn-primary" onclick="generateToken()">Generate Token</button>
                    </div>
                    <button class="btn btn-outline-secondary btn-sm w-100 mb-3" onclick="copyToken()">Salin ke Clipboard</button>
                </div>

                <div class="card portal-card shadow-sm p-4 mb-4 border-primary">
                    <h5 class="fw-bold mb-3 text-primary">🚀 API Simulator (Live Test 6 Aplikasi)</h5>
                    <p class="small text-muted">Uji kirim request ke semua layanan ekosistem (Biaya Rp 500/request).</p>
                    
                    <div class="mb-3">
                        <label class="form-label small fw-bold">1. Pilih Aplikasi Tujuan</label>
                        <select id="testEndpoint" class="form-select">
                            <option value="/integrator/smartbank/pembayaran">1. SmartBank - Pembayaran & Saldo</option>
                            <option value="/integrator/marketplace/orders">2. Marketplace - Pesanan Produk</option>
                            <option value="/integrator/logistik/shipping">3. LogistiKita - Pengiriman Barang</option>
                            <option value="/integrator/supplier/restock">4. SupplierHub - Stok Bahan Baku</option>
                            <option value="/integrator/pos/transaction">5. POS / Kasir - Transaksi Toko</option>
                            <option value="/integrator/umkm-insight/analytics">6. UMKM Insight - Analitik Data</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold">2. Token Bearer</label>
                        <input type="text" id="testToken" class="form-control" placeholder="Tempel token di sini...">
                    </div>

                    <button onclick="jalankanTes()" class="btn btn-success w-100 fw-bold">Kirim Request Sekarang</button>
                    
                    <div class="mt-4">
                        <label class="form-label small fw-bold">Server Response:</label>
                        <div class="code-area small" id="jsonResponse">
                            // Respon JSON akan muncul di sini...
                        </div>
                    </div>
                </div>

                <div class="card portal-card shadow-sm p-4">
                    <h5 class="fw-bold mb-3">📖 Panduan Singkat</h5>
                    <p class="small">Gunakan Header berikut pada aplikasi Anda:</p>
                    <div class="code-area small bg-light text-dark">
                        Authorization: Bearer [TOKEN_ANDA]
                    </div>
                    <p class="small mt-3 text-muted">Setiap request sukses tercatat otomatis dan dikenakan biaya <strong>Rp 500</strong>.</p>
                </div>
                
                <footer class="mt-5 text-center text-muted small">
                    Integrator System &copy; 2026 - Richard Firmansya & Zidan Hairra Ramadhan
                </footer>
            </div>
        </div>
    </div>

    <script>
        async function generateToken() {
            const res = await fetch('/generate-test-token');
            const data = await res.json();
            const output = document.getElementById('tokenOutput');
            output.value = data.token;
            document.getElementById('testToken').value = data.token;
        }

        function copyToken() {
            const el = document.getElementById("tokenOutput");
            if(!el.value) return alert("Generate token dulu!");
            el.select();
            document.execCommand("copy");
            alert("Token berhasil disalin!");
        }

        async function jalankanTes() {
            const endpoint = document.getElementById('testEndpoint').value;
            const token = document.getElementById('testToken').value;
            const responseBox = document.getElementById('jsonResponse');

            if(!token) return alert("Error: Token wajib diisi!");

            responseBox.innerText = "// Sedang memproses request...";
            responseBox.style.color = "#fbbf24"; // text-warning

            try {
                const res = await fetch(endpoint, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': 'Bearer ' + token
                    },
                    body: JSON.stringify({ 
                        status: "Testing",
                        message: "Request Simulasi Integrasi UMKM",
                        developer: "Kelompok 7"
                    })
                });

                const data = await res.json();
                responseBox.innerText = JSON.stringify(data, null, 2);
                responseBox.style.color = "#38bdf8"; // text-success
            } catch (err) {
                responseBox.innerText = "// Error: " + err.message;
                responseBox.style.color = "#f87171"; // text-danger
            }
        }
    </script>
</body>
</html>