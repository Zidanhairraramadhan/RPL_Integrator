<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gateway Integrator</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .hero-section {
            background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
            color: white;
            padding: 100px 0;
        }
        .feature-card {
            border: none;
            transition: transform 0.3s;
        }
        .feature-card:hover { transform: translateY(-10px); }
    </style>
</head>
<body>
    <header class="hero-section text-center">
        <div class="container">
            <h1 class="display-3 fw-bold mb-3">API Gateway Integrator</h1>
            <p class="lead mb-4">Middleware Pengendali Ekosistem Ekonomi UMKM</p>
            
            <div class="d-grid gap-2 d-sm-flex justify-content-sm-center mb-4">
                <!-- Rute ke Dashboard Admin -->
                <a href="/dashboard" class="btn btn-light btn-lg px-4">Buka Dashboard Admin</a>
                
                <!-- Rute ke Download Dokumentasi PDF (Fitur Baru) -->
                <a href="/download-docs" class="btn btn-outline-light btn-lg px-4">Dokumentasi API</a>
            </div>

            <!-- Tombol Tambahan untuk Kelompok Lain -->
            <div class="justify-content-center">
                <a href="/client-portal" class="text-white small text-decoration-none">
                    🔑 Akses Client Portal (Ambil Token Mandiri)
                </a>
            </div>
        </div>
    </header>

    <section class="container my-5">
        <div class="row g-4 text-center">
            <div class="col-md-3">
                <div class="card h-100 feature-card shadow-sm p-3">
                    <div class="fs-1 text-primary">🛡️</div>
                    <h5 class="mt-3">Security & Auth</h5>
                    <p class="small text-muted">Validasi JWT wajib untuk menjamin keamanan sistem sesuai aturan nomor 6.</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 feature-card shadow-sm p-3">
                    <div class="fs-1 text-primary">📑</div>
                    <h5 class="mt-3">Real-time Logging</h5>
                    <p class="small text-muted">Setiap request dicatat secara otomatis untuk keperluan audit aktivitas sistem[cite: 1].</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 feature-card shadow-sm p-3">
                    <div class="fs-1 text-primary">🚀</div>
                    <h5 class="mt-3">API Routing</h5>
                    <p class="small text-muted">Orchestrator tunggal yang menghubungkan Marketplace ke SmartBank secara aman[cite: 1].</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 feature-card shadow-sm p-3">
                    <div class="fs-1 text-primary">💰</div>
                    <h5 class="mt-3">Monetisasi</h5>
                    <p class="small text-muted">Penerapan biaya layanan Rp 500 per request sesuai aturan nomor 9[cite: 1].</p>
                </div>
            </div>
        </div>
    </section>

    <footer class="text-center py-4 border-top">
        <p class="text-muted mb-0">D4 Teknik Informatika - ULBI &copy; 2026</p>
    </footer>
</body>
</html>